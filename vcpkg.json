{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "autodos2",
  "version": "0.1.0",
  "description": "Cross-platform DOS game frontend",
  "dependencies": [
    {
      "name": "sdl2",
      "features": ["default"]
    },
    "sdl2-image",
    "sdl2-ttf",
    {
      "name": "imgui",
      "features": [
        "sdl2-binding",
        "sdl2-renderer-binding"
      ]
    },
    "nlohmann-json"
  ],
  "builtin-baseline": "dbbd673624c057174dd51ef85758951032717715",
  "overrides": []
}
